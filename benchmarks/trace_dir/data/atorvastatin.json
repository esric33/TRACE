{
"snippets": [
{
"snippet_id": "atorvastatin_lead_use_01",
"source": "[https://en.wikipedia.org/wiki/Atorvastatin](https://en.wikipedia.org/wiki/Atorvastatin)",
"section": "Lead",
"text": "Atorvastatin, sold under the brand name Lipitor among others, is a statin medication used to prevent cardiovascular disease in those at high risk and to treat abnormal lipid levels."
},
{
"snippet_id": "atorvastatin_lead_adverse_warning_01",
"source": "[https://en.wikipedia.org/wiki/Atorvastatin](https://en.wikipedia.org/wiki/Atorvastatin)",
"section": "Lead",
"text": "Common side effects may include diarrhea, heartburn, nausea, muscle pain (typically mild and dose-dependent) and, less frequently, joint pain. Muscle symptoms often occur during the first year and are commonly influenced by pre-existing health issues and the nocebo effect. Most patients can continue therapy with dose adjustment or statin switching. Rare (<0.1%) but serious side effects may include rhabdomyolysis (severe muscle disorder), liver problems and diabetes. Use during pregnancy may harm the fetus."
},
{
"snippet_id": "atorvastatin_lead_mechanism_01",
"source": "[https://en.wikipedia.org/wiki/Atorvastatin](https://en.wikipedia.org/wiki/Atorvastatin)",
"section": "Lead",
"text": "Like all statins, atorvastatin works by inhibiting HMG-CoA reductase, an enzyme found in the liver that plays a role in producing cholesterol."
},
{
"snippet_id": "atorvastatin_medical_uses_01",
"source": "[https://en.wikipedia.org/wiki/Atorvastatin](https://en.wikipedia.org/wiki/Atorvastatin)",
"section": "Medical uses",
"text": "The primary uses of atorvastatin are for the treatment of dyslipidemia and for the prevention of cardiovascular disease."
},
{
"snippet_id": "atorvastatin_dyslipidemia_01",
"source": "[https://en.wikipedia.org/wiki/Atorvastatin](https://en.wikipedia.org/wiki/Atorvastatin)",
"section": "Medical uses / Dyslipidemia",
"text": "Hypercholesterolemia (heterozygous familial and nonfamilial) and mixed dyslipidemia (Fredrickson types IIa and IIb) to reduce total cholesterol, LDL-C, apo-B, triglycerides levels, and CRP as well as increase HDL levels"
},
{
"snippet_id": "atorvastatin_dyslipidemia_02",
"source": "[https://en.wikipedia.org/wiki/Atorvastatin](https://en.wikipedia.org/wiki/Atorvastatin)",
"section": "Medical uses / Dyslipidemia",
"text": "Heterozygous familial hypercholesterolemia in children"
},
{
"snippet_id": "atorvastatin_dyslipidemia_03",
"source": "[https://en.wikipedia.org/wiki/Atorvastatin](https://en.wikipedia.org/wiki/Atorvastatin)",
"section": "Medical uses / Dyslipidemia",
"text": "Homozygous familial hypercholesterolemia"
},
{
"snippet_id": "atorvastatin_dyslipidemia_04",
"source": "[https://en.wikipedia.org/wiki/Atorvastatin](https://en.wikipedia.org/wiki/Atorvastatin)",
"section": "Medical uses / Dyslipidemia",
"text": "Hypertriglyceridemia (Fredrickson Type IV)"
},
{
"snippet_id": "atorvastatin_dyslipidemia_05",
"source": "[https://en.wikipedia.org/wiki/Atorvastatin](https://en.wikipedia.org/wiki/Atorvastatin)",
"section": "Medical uses / Dyslipidemia",
"text": "Primary dysbetalipoproteinemia (Fredrickson Type III)"
},
{
"snippet_id": "atorvastatin_dyslipidemia_06",
"source": "[https://en.wikipedia.org/wiki/Atorvastatin](https://en.wikipedia.org/wiki/Atorvastatin)",
"section": "Medical uses / Dyslipidemia",
"text": "Combined hyperlipidemia"
},
{
"snippet_id": "atorvastatin_cardiovascular_01",
"source": "[https://en.wikipedia.org/wiki/Atorvastatin](https://en.wikipedia.org/wiki/Atorvastatin)",
"section": "Medical uses / Cardiovascular disease",
"text": "Primary prevention of heart attack, stroke, and need for revascularization procedures in people who have risk factors such as age, smoking, high blood pressure, low HDL-C, and a family history of early heart disease, but have not yet developed evidence of coronary artery disease."
},
{
"snippet_id": "atorvastatin_contraindications_01",
"source": "[https://en.wikipedia.org/wiki/Atorvastatin](https://en.wikipedia.org/wiki/Atorvastatin)",
"section": "Contraindications",
"text": "Active liver disease: cholestasis, hepatic encephalopathy, hepatitis, and jaundice"
},
{
"snippet_id": "atorvastatin_contraindications_pregnancy_01",
"source": "[https://en.wikipedia.org/wiki/Atorvastatin](https://en.wikipedia.org/wiki/Atorvastatin)",
"section": "Contraindications",
"text": "Pregnancy: Atorvastatin is classified as a pregnancy category X medication by the U.S. Food and Drug Administration (FDA), indicating that it is contraindicated during pregnancy due to evidence of potential harm to the fetus and a lack of demonstrated benefit in this population."
},
{
