{
"snippets": [
{
"snippet_id": "morphine_lead_class_use_mechanism_01",
"source": "[https://en.wikipedia.org/wiki/Morphine](https://en.wikipedia.org/wiki/Morphine)",
"section": "Lead",
"text": "Morphine, formerly known as morphium, is an opiate found naturally in opium, a dark brown resin produced by drying the latex of opium poppies (Papaver somniferum). It is mainly used as an analgesic (pain medication)."
},
{
"snippet_id": "morphine_lead_mechanism_01",
"source": "[https://en.wikipedia.org/wiki/Morphine](https://en.wikipedia.org/wiki/Morphine)",
"section": "Lead",
"text": "It acts directly on the central nervous system (CNS) to induce analgesia and alter perception and emotional response to pain."
},
{
"snippet_id": "morphine_lead_use_01",
"source": "[https://en.wikipedia.org/wiki/Morphine](https://en.wikipedia.org/wiki/Morphine)",
"section": "Lead",
"text": "It can be taken for both acute pain and chronic pain and is frequently used for pain from myocardial infarction, kidney stones, and during labor."
},
{
"snippet_id": "morphine_lead_adverse_warning_01",
"source": "[https://en.wikipedia.org/wiki/Morphine](https://en.wikipedia.org/wiki/Morphine)",
"section": "Lead",
"text": "Common side effects of morphine include drowsiness, euphoria, nausea, dizziness, sweating, and constipation. Potentially serious side effects of morphine include decreased respiratory effort, vomiting, and low blood pressure. Morphine is highly addictive and prone to abuse."
},
{
"snippet_id": "morphine_lead_pregnancy_warning_01",
"source": "[https://en.wikipedia.org/wiki/Morphine](https://en.wikipedia.org/wiki/Morphine)",
"section": "Lead",
"text": "Caution is advised for the use of morphine during pregnancy or breastfeeding, as it may affect the health of the baby."
},
{
"snippet_id": "morphine_medical_uses_pain_01",
"source": "[https://en.wikipedia.org/wiki/Morphine](https://en.wikipedia.org/wiki/Morphine)",
"section": "Medical uses / Pain",
"text": "Morphine is used primarily to treat both acute and chronic severe pain."
},
{
"snippet_id": "morphine_medical_uses_pain_02",
"source": "[https://en.wikipedia.org/wiki/Morphine](https://en.wikipedia.org/wiki/Morphine)",
"section": "Medical uses / Pain",
"text": "It is used for pain due to myocardial infarction and for labor pains."
},
{
"snippet_id": "morphine_medical_uses_pain_03",
"source": "[https://en.wikipedia.org/wiki/Morphine](https://en.wikipedia.org/wiki/Morphine)",
"section": "Medical uses / Pain",
"text": "Morphine has also traditionally been used in the treatment of acute pulmonary edema."
},
{
"snippet_id": "morphine_medical_uses_pain_04",
"source": "[https://en.wikipedia.org/wiki/Morphine](https://en.wikipedia.org/wiki/Morphine)",
"section": "Medical uses / Pain",
"text": "A 2016 Cochrane review concluded that morphine is effective in relieving cancer pain."
},
{
"snippet_id": "morphine_medical_uses_breathlessness_01",
"source": "[https://en.wikipedia.org/wiki/Morphine](https://en.wikipedia.org/wiki/Morphine)",
"section": "Medical uses / Shortness of breath",
"text": "Morphine is beneficial in reducing the symptom of shortness of breath due to both cancer and non-cancer causes."
},
{
"snippet_id": "morphine_medical_uses_opioid_use_disorder_01",
"source": "[https://en.wikipedia.org/wiki/Morphine](https://en.wikipedia.org/wiki/Morphine)",
"section": "Medical uses / Opioid use disorder",
"text": "Morphine is used in a slow-release formulation for opiate substitution therapy (OST) in Austria, Germany, Bulgaria, Slovenia, and Canada for persons with opioid addiction who cannot tolerate either methadone or buprenorphine."
},
{
"snippet_id": "morphine_contraindications_01",
"source": "[https://en.wikipedia.org/wiki/Morphine](https://en.wikipedia.org/wiki/Morphine)",
"section": "Contraindications",
"text": "Relative contraindications to morphine include: Respiratory depression when appropriate equipment is not available."
},
{
"snippet_id": "morphine_adverse_effects_01",
"source": "[https://en.wikipedia.org/wiki/Morphine](https://en.wikipedia.org/wiki/Morphine)",
"section": "Adverse effects",
"text": "Common and short term: Itchiness; Nausea; Vomiting; Constipation; Drowsiness; Dry mouth; Respiratory depression."
},
{
"snippet_id": "morphine_adverse_effects_02",
"source": "[https://en.wikipedia.org/wiki/Morphine](https://en.wikipedia.org/wiki/Morphine)",
"section": "Adverse effects",
"text": "Other: Opioid dependence; Dizziness; Decreased sex drive; Loss of appetite; Impaired sexual function; Decreased testosterone levels; Depression; Immunodeficiency; Opioid-induced abnormal pain sensitivity; Irregular menstruation; Increased risk of falls; Slowed breathing; Hallucinations."
},
{
"snippet_id": "morphine_constipation_01",
"source": "[https://en.wikipedia.org/wiki/Morphine](https://en.wikipedia.org/wiki/Morphine)",
"section": "Adverse effects / Constipation",
"text": "Like loperamide and other opioids, morphine acts on the myenteric plexus in the intestinal tract, reducing gut motility, and causing constipation."
},
{
"snippet_id": "morphine_constipation_mechanism_01",
"source": "[https://en.wikipedia.org/wiki/Morphine](https://en.wikipedia.org/wiki/Morphine)",
"section": "Adverse effects / Constipation",
"text": "The gastrointestinal effects of morphine are mediated primarily by μ-opioid receptors in the bowel. By inhibiting gastric emptying and reducing propulsive peristalsis of the intestine, morphine decreases the rate of intestinal transit."
},
{
"snippet_id": "morphine_hormone_imbalance_01",
"source": "[https://en.wikipedia.org/wiki/Morphine](https://en.wikipedia.org/wiki/Morphine)",
"section": "Adverse effects / Hormone imbalance",
"text": "Clinical studies consistently conclude that morphine, like other opioids, often causes hypogonadism and hormone imbalances in chronic users of both sexes. Morphine can interfere with menstruation by suppressing levels of luteinizing hormone."
},
{
"snippet_id": "morphine_hormone_imbalance_02",
"source": "[https://en.wikipedia.org/wiki/Morphine](https://en.wikipedia.org/wiki/Morphine)",
"section": "Adverse effects / Hormone imbalance",
"text": "This effect may cause the increased likelihood of osteoporosis and bone fracture observed in chronic morphine users."
},
{
"snippet_id": "morphine_performance_01",
"source": "[https://en.wikipedia.org/wiki/Morphine](https://en.wikipedia.org/wiki/Morphine)",
"section": "Adverse effects / Effects on human performance",
"text": "Morphine has resulted in impaired functioning on critical flicker frequency and impaired performance on the Maddox wing test."
},
{
"snippet_id": "morphine_performance_02",
"source": "[https://en.wikipedia.org/wiki/Morphine](https://en.wikipedia.org/wiki/Morphine)",
"section": "Adverse effects / Effects on human performance",
"text": "In terms of cognitive abilities, one study has shown that morphine may negatively impact anterograde and retrograde memory."
},
{
"snippet_id": "morphine_addiction_01",
"source": "[https://en.wikipedia.org/wiki/Morphine](https://en.wikipedia.org/wiki/Morphine)",
"section": "Adverse effects / Reinforcement disorders / Addiction",
"text": "Morphine is a highly addictive substance."
},
{
"snippet_id": "morphine_toxicity_01",
"source": "[https://en.wikipedia.org/wiki/Morphine](https://en.wikipedia.org/wiki/Morphine)",
"section": "Toxicity",
"text": "A large overdose can cause asphyxia and death by respiratory depression if the person does not receive medical attention immediately."
},
{
"snippet_id": "morphine_pharmacodynamics_01",
"source": "[https://en.wikipedia.org/wiki/Morphine](https://en.wikipedia.org/wiki/Morphine)",
"section": "Pharmacology / Pharmacodynamics",
"text": "Morphine is a phenanthrene opioid receptor agonist – its main effect is binding to and activating the μ-opioid receptor (MOR) in the central nervous system."
},
{
"snippet_id": "morphine_pharmacodynamics_02",
"source": "[https://en.wikipedia.org/wiki/Morphine](https://en.wikipedia.org/wiki/Morphine)",
"section": "Pharmacology / Pharmacodynamics",
"text": "In clinical settings, morphine exerts its principal pharmacological effect on the central nervous system and gastrointestinal tract. Its primary actions of therapeutic value are analgesia and sedation."
},
{
"snippet_id": "morphine_pharmacodynamics_03",
"source": "[https://en.wikipedia.org/wiki/Morphine](https://en.wikipedia.org/wiki/Morphine)",
"section": "Pharmacology / Pharmacodynamics",
"text": "Activation of the MOR is associated with analgesia, sedation, euphoria, physical dependence, and respiratory depression. Morphine is also a κ-opioid receptor (KOR) and δ-opioid receptor (DOR) agonist."
}
],
